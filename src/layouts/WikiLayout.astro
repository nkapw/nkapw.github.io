---
import '../styles/global.css';
import type { MarkdownHeading } from 'astro';
import { getWikiPages } from '../lib/wiki';

interface Props {
  title: string;
  description?: string;
  // When present, render a table-of-contents sidebar (desktop only).
  headings?: MarkdownHeading[];
  // Breadcrumb trail (built from the page's folder structure). The last
  // crumb has no href — it is the current page.
  crumbs?: { label: string; href?: string }[];
}

const { title, description, headings = [], crumbs = [] } = Astro.props;

// Only h2/h3 make a useful TOC; h1 is the page title.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = toc.length > 0;

const pages = await getWikiPages();
const pageCount = pages.length;
const lastUpdated = pages
  .map((p) => p.data.updated)
  .filter((d): d is Date => d instanceof Date)
  .sort((a, b) => b.getTime() - a.getTime())[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Personal Wiki" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    <link rel="alternate" type="application/rss+xml" title="Personal Wiki" href="/rss.xml" />
  </head>
  <body>
    <!-- Centered column. Widen it when a TOC sidebar is present. Tailwind = layout only. -->
    <div class={`${hasToc ? 'max-w-4xl' : 'max-w-2xl'} mx-auto px-4 py-6`}>
      <header data-pagefind-ignore>
        <strong>Personal Wiki</strong>
        <nav>
          <a href="/">Home</a> |
          <a href="/#all-pages">All Pages</a> |
          <a href="/tutorial/">Tutorial</a> |
          <a href="/tags/">Tags</a> |
          <a href="/stats/">Stats</a> |
          <a href="/search/">Search</a>
        </nav>
      </header>

      <hr />

      {
        crumbs.length > 0 && (
          <nav aria-label="Breadcrumb">
            {crumbs.map((c, i) => (
              <>
                {i > 0 && ' / '}
                {c.href ? <a href={c.href}>{c.label}</a> : c.label}
              </>
            ))}
          </nav>
        )
      }

      {
        hasToc ? (
          <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-8">
            <nav aria-label="Table of contents">
              <p><strong>On this page</strong></p>
              <ul>
                {toc.map((h) => (
                  <li>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
            <main data-pagefind-body>
              <slot />
            </main>
          </div>
        ) : (
          <main data-pagefind-body>
            <slot />
          </main>
        )
      }

      <hr />

      <footer data-pagefind-ignore>
        <p>
          {pageCount} page{pageCount === 1 ? '' : 's'}.
          {lastUpdated && (
            <>
              {' '}Last updated{' '}
              {lastUpdated.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}.
            </>
          )}
        </p>
      </footer>
    </div>

    <!-- Heading anchors: append a § link to every heading that has an id,
         so individual sections can be deep-linked. Pure JS, no extra package. -->
    <script>
      document.querySelectorAll('main h2[id], main h3[id], main h4[id]').forEach((h) => {
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.setAttribute('aria-hidden', 'true');
        a.setAttribute('tabindex', '-1');
        a.textContent = ' §';
        h.append(a);
      });
    </script>
  </body>
</html>
